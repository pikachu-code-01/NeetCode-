class Solution {
    public boolean isAnagram(String s, String t) {
          if(s.length() != t.length()) return false;
          int[] lettersCount = new int[26];
          for(int i = 0;i<s.length();i++)
          {
            lettersCount[s.charAt(i) - 'a']++;
            lettersCount[t.charAt(i) - 'a']--;
          }
          for(int c : lettersCount)
          {
            if(c!=0) return false;
          }
          return true;
    }
}
