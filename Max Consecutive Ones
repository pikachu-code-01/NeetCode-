class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int max =0;
         int curOnes = 0;
        for(int i =0;i<nums.length;i++)
        {
           
            if(nums[i] == 1) {
                curOnes++;
                if(curOnes > max){ max = curOnes;}
               
            }
            else {
                curOnes =0;
            }

        }
        return max;
    }
}
