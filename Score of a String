class Solution {
    public int scoreOfString(String s) {
        int ans = 0;
        for(int i =0;i<s.length() - 1;i++)
        {
          //  char ch = s.charAt(i);
           // char ch2 = s.charAt(i+1);
           // int num1 =(int)ch;
          //  int num2 = (int)ch2;
          int num1 = s.charAt(i);
          int num2 = s.charAt(i+1);
            ans =(ans)+(Math.abs(num2-num1));

        }
        return ans;
    }
}
